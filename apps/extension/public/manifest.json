{
  "manifest_version": 3,
  "name": "Sanchay",
  "version": "0.0.1",
  "description": "Save any page to Sanchay with one click",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:3001/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Sanchay"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
